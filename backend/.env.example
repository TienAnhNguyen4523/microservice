# ─────────────────────────────────────────────────────────────
#  MERN E-Commerce – Environment Variables
#  Copy this file to .env (it is git-ignored)
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/huxnStore

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
NODE_ENV=development

# ── Service Ports ─────────────────────────────────────────────
GATEWAY_PORT=5000
PRODUCT_SERVICE_PORT=5001
ORDER_SERVICE_PORT=5002
INVENTORY_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
USER_SERVICE_PORT=5005

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost

# ── PayPal (optional) ─────────────────────────────────────────
PAYPAL_CLIENT_ID=
