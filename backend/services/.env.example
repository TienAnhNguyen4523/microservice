# ──────────────────────────────────────────────────────────
# Shared .env for all microservices
# Copy this to each service directory: cp .env.services services/api-gateway/.env
# (or point each service's dotenv to this file)
# ──────────────────────────────────────────────────────────

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/huxnStore

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Service Ports (optional – defaults are hardcoded in each service)
GATEWAY_PORT=5000
PRODUCT_SERVICE_PORT=5001
ORDER_SERVICE_PORT=5002
INVENTORY_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
USER_SERVICE_PORT=5005

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# Environment
NODE_ENV=development
